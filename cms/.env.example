# CMS Environment Variables
# Copy file ini ke .env dan isi dengan nilai yang sesuai

# JWT Secret - Ganti dengan string acak yang panjang dan kuat
JWT_SECRET=ganti_dengan_secret_yang_kuat_dan_panjang_minimal_32_karakter

# Kredensial admin awal (digunakan saat user admin pertama kali dibuat)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_dengan_password_yang_kuat

# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Port server CMS
CMS_PORT=5000
